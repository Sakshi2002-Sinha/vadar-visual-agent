# .env.example
# Copy this file to .env and fill in your values.
# Load it with: source .env  (bash) or use python-dotenv in Python.

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Required for the code-generation step.
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# ── Hardware ─────────────────────────────────────────────────────────────────
# Set to "1" if a CUDA-capable GPU is available (optional, defaults to CPU).
CUDA_AVAILABLE=0

# ── Paths (optional) ─────────────────────────────────────────────────────────
# Override the default directory where benchmark results are stored.
# BENCHMARK_OUTPUT_DIR=benchmark_results

# Override the default directory for sample images.
# SAMPLE_IMAGES_DIR=sample_images
