# ============================================================
# VADAR Visual Agent – Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your actual .env file to version control.
# ============================================================

# ------------------------------------------------------------
# LLM Provider Routing
# ------------------------------------------------------------

# Provider strategy: auto | github | openai | local
# auto: GitHub Models first (if GITHUB_TOKEN is set), then OpenAI, then local fallback
LLM_PROVIDER=auto

# ------------------------------------------------------------
# OpenAI API
# ------------------------------------------------------------

# Your OpenAI secret key (optional if using provider=github or provider=local)
OPENAI_API_KEY=sk-your-key-here

# OpenAI model used for spatial-reasoning code generation.
# Options depend on your account and endpoint.
OPENAI_MODEL=gpt-4o

# Optional OpenAI-compatible base URL (leave blank for api.openai.com)
# For GitHub Models keep this blank and use GITHUB_BASE_URL instead.
OPENAI_BASE_URL=

# ------------------------------------------------------------
# GitHub Models
# ------------------------------------------------------------

# GitHub personal access token used for GitHub Models API calls
# Suggested scopes: read-only model inference access according to GitHub docs.
GITHUB_TOKEN=

# GitHub Models endpoint base URL
GITHUB_BASE_URL=https://models.inference.ai.azure.com

# Model ID for GitHub Models (example)
GITHUB_MODEL=gpt-4o-mini

# Maximum tokens to generate per code completion
OPENAI_MAX_TOKENS=1500

# Sampling temperature (0 = deterministic, 1 = creative)
OPENAI_TEMPERATURE=0.3

# ------------------------------------------------------------
# HuggingFace Model Cache
# ------------------------------------------------------------

# Where to store downloaded HuggingFace model weights.
# Defaults to ~/.cache/huggingface if not set.
# HF_HOME=/mnt/large_disk/.cache/huggingface

# ------------------------------------------------------------
# CUDA / GPU Settings
# ------------------------------------------------------------

# Set to "1" to force CPU even when a GPU is present.
# FORCE_CPU=0

# CUDA device index to use (0 = first GPU)
# CUDA_VISIBLE_DEVICES=0

# ------------------------------------------------------------
# Model Paths (optional overrides)
# ------------------------------------------------------------

# Use a locally downloaded or fine-tuned model instead of the
# HuggingFace Hub ID.
# OBJECT_DETECTION_MODEL=facebook/detr-resnet-50
# DEPTH_ESTIMATION_MODEL=Intel/dpt-large
# SEGMENTATION_MODEL=facebook/detr-resnet-50-panoptic

# ------------------------------------------------------------
# Evaluation & Output
# ------------------------------------------------------------

# Default output directory for evaluation results
OUTPUT_DIR=outputs

# Whether to save visual traces (PNG files) during evaluation
# Set to "0" to disable and speed up evaluation
SAVE_TRACES=1

# Whether to save generated Python code files
SAVE_CODE=1
