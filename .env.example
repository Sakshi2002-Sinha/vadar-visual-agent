# ============================================================
# VADAR Visual Agent – Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your actual .env file to version control.
# ============================================================

# ------------------------------------------------------------
# OpenAI API
# ------------------------------------------------------------

# Your OpenAI secret key (required for code generation)
OPENAI_API_KEY=sk-your-key-here

# OpenAI model used for spatial-reasoning code generation.
# Options: gpt-4o (default, best quality), gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# Maximum tokens to generate per code completion
OPENAI_MAX_TOKENS=1500

# Sampling temperature (0 = deterministic, 1 = creative)
OPENAI_TEMPERATURE=0.3

# ------------------------------------------------------------
# HuggingFace Model Cache
# ------------------------------------------------------------

# Where to store downloaded HuggingFace model weights.
# Defaults to ~/.cache/huggingface if not set.
# HF_HOME=/mnt/large_disk/.cache/huggingface

# ------------------------------------------------------------
# CUDA / GPU Settings
# ------------------------------------------------------------

# Set to "1" to force CPU even when a GPU is present.
# FORCE_CPU=0

# CUDA device index to use (0 = first GPU)
# CUDA_VISIBLE_DEVICES=0

# ------------------------------------------------------------
# Model Paths (optional overrides)
# ------------------------------------------------------------

# Use a locally downloaded or fine-tuned model instead of the
# HuggingFace Hub ID.
# OBJECT_DETECTION_MODEL=facebook/detr-resnet-50
# DEPTH_ESTIMATION_MODEL=Intel/dpt-large
# SEGMENTATION_MODEL=facebook/detr-resnet-50-panoptic

# ------------------------------------------------------------
# Evaluation & Output
# ------------------------------------------------------------

# Default output directory for evaluation results
OUTPUT_DIR=outputs

# Whether to save visual traces (PNG files) during evaluation
# Set to "0" to disable and speed up evaluation
SAVE_TRACES=1

# Whether to save generated Python code files
SAVE_CODE=1
